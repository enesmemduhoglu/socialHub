# PostgreSQL
POSTGRES_DB=socialhub
POSTGRES_USER=socialhub
POSTGRES_PASSWORD=socialhub

# Uygulama veritabanı bağlantısı (application.yml tarafından okunur)
DB_URL=jdbc:postgresql://localhost:5433/socialhub
DB_USERNAME=socialhub
DB_PASSWORD=socialhub

# JWT — üretimde MUTLAKA güçlü, rastgele ve en az 32 karakterlik bir secret verin
JWT_SECRET=change-me-in-production-please-use-a-long-random-secret-key
JWT_EXPIRATION_MS=3600000

# Redis (feed cache)
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS — frontend origin'leri (virgülle ayrılır)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
